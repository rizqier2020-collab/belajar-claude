# ================================
# Konfigurasi Backend JFP
# ================================

# Database
# Development (SQLite):
#   DATABASE_URL=sqlite:///./jfp.db
# Production (PostgreSQL) — sesuaikan dengan docker-compose:
DATABASE_URL=postgresql://jfp_user:jfp_password@db:5432/jfp_db

# JWT — WAJIB ganti di produksi dengan string acak yang panjang!
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-this-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Upload file
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=5242880
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf

# CORS — origin frontend yang diizinkan (pisahkan dengan koma)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
