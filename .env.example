# ================================================
# Konfigurasi docker-compose (produksi)
# ================================================
# Copy file ini menjadi `.env` di folder yang sama dengan docker-compose.yml,
# lalu isi nilai di bawah dengan nilai yang AMAN sebelum menjalankan:
#   docker compose up -d --build
#
# JANGAN commit file .env (sudah di-ignore oleh .gitignore).

# --- Database ---
POSTGRES_USER=jfp_user
# WAJIB diganti — jangan pakai nilai contoh ini di produksi!
POSTGRES_PASSWORD=ganti-dengan-password-kuat
POSTGRES_DB=jfp_db

# --- JWT ---
# WAJIB diganti dengan string acak yang panjang.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=ganti-dengan-secret-key-acak

# --- CORS ---
# Alamat frontend yang boleh mengakses API — sesuaikan dengan domain/IP server Anda.
# Contoh setelah punya domain: https://cuti.jfp.co.id
CORS_ORIGINS=http://localhost:3000
